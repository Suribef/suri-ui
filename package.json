{
  "name": "@suribef/suri-ui",
  "version": "0.1.0",
  "description": "React component library by Sergio Uribe Frenkel",
  "author": "Sergio Uribe Frenkel (@Suribef)",
  "license": "MIT",
  "homepage": "https://suribef.github.io/suri-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suribef/suri-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Suribef/suri-ui/issues"
  },
  "type": "module",
  "main": "./dist/suri-ui.cjs",
  "module": "./dist/suri-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/suri-ui.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/suri-ui.cjs"
      }
    },
    "./styles": "./dist/suri-ui.css"
  },
  "files": [
    "dist/components",
    "dist/utils",
    "dist/index.d.ts",
    "dist/suri-ui.js",
    "dist/suri-ui.cjs",
    "dist/suri-ui.css"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "components",
    "typescript",
    "ui",
    "component-library"
  ],
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-replace": "^6.0.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
